# ── Django Core ────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=dzmock.uz,www.dzmock.uz,localhost
CSRF_TRUSTED_ORIGINS=https://dzmock.uz,https://www.dzmock.uz

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
DB_NAME=cdi_db
DB_USER=cdi_user
DB_PASSWORD=your-strong-db-password
DB_HOST=db
DB_PORT=5432

# ── Deployment ──────────────────────────────────────────────────────────────────
DOMAIN_NAME=dzmock.uz
LOG_DOMAIN=logs.dzmock.uz

# ── Dozzle Basic Auth (set by setup-server.sh) ──────────────────────────────────
DOZZLE_USERNAME=changeme
DOZZLE_PASSWORD=changeme
